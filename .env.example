# Environment Variables

# PostgreSQL connection string
# Example (local): postgres://username:password@localhost:5432/reimbursements_db
DATABASE_URL=postgres://username:password@localhost:5432/reimbursements_db

# Secret used to sign cookies — use a long random string in production
SESSION_SECRET=change_me_to_a_long_random_secret

# Port (must be 7002 per spec)
PORT=7002
